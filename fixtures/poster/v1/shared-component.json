{
  "schema": "capy.poster.document.v1",
  "id": "shared-component-poster",
  "title": "Shared Component Poster",
  "viewport": {
    "w": 1920,
    "h": 1080,
    "ratio": "16:9"
  },
  "theme": {
    "background": "#fffaf0",
    "accent": "#a78bfa"
  },
  "assets": {},
  "components": {
    "html.capy-title": {
      "package": "../../components/html.capy-title/component.json"
    }
  },
  "pages": [
    {
      "id": "component-page",
      "title": "Component",
      "background": "#fffaf0",
      "layers": [
        {
          "id": "shared-title",
          "kind": "component",
          "component": "html.capy-title",
          "bounds": { "x": 0, "y": 0, "w": 1920, "h": 1080 },
          "z": 1,
          "params": {
            "eyebrow": "POSTER / VIDEO COMPONENT",
            "title": "组件跟视频共用",
            "subtitle": "静态海报 progress=0，视频时间线按 playhead 更新同一组件。",
            "metric": "html.capy-title",
            "accent": "mint"
          },
          "style": {}
        }
      ]
    }
  ],
  "exports": {
    "default": ["png", "pdf", "json"]
  }
}
