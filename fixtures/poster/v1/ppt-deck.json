        {
          "id": "stamp",
          "kind": "text",
          "text": "verified",
          "bounds": { "x": 1360, "y": 680, "w": 320, "h": 80 },
          "z": 5,
          "style": { "fontSize": 54, "fontWeight": 900, "color": "#3da065" }
        }
      ]
    }
