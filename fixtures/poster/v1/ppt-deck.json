        {
          "id": "selection-box",
          "kind": "shape",
          "shape": "rect",
          "bounds": { "x": 250, "y": 430, "w": 560, "h": 330 },
          "z": 2,
          "style": { "fill": "rgba(255,250,240,.75)", "radius": 36, "borderColor": "#a78bfa", "borderWidth": 8 }
        },
        {
          "id": "selection-text",
          "kind": "text",
          "text": "layer_path\nbounds\ncopy\nstyle\nasset refs",
          "bounds": { "x": 310, "y": 485, "w": 430, "h": 220 },
          "z": 3,
          "style": { "fontSize": 38, "fontWeight": 800, "color": "#1c1917", "lineHeight": 1.22 }
        }
      ]
    },
    {
      "id": "p3",
      "title": "Patch",
      "background": "#ede9fe",
      "layers": [
        {
          "id": "bg",
          "kind": "shape",
          "shape": "rect",
          "bounds": { "x": 0, "y": 0, "w": 1920, "h": 1080 },
